# Server Configuration
PORT=4040
NODE_ENV=development
SESSION_SECRET=your_secure_session_secret_here

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# Microsoft Copilot / Azure OpenAI Configuration
COPILOT_API_KEY=your_copilot_api_key_here
COPILOT_ENDPOINT=https://your-resource-name.openai.azure.com/
COPILOT_MODEL=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Optional: Internal API Key for machine-to-machine auth
AGENT_API_KEY=your_secret_agent_key
INTERNAL_API_KEY=your_secret_internal_key

# News API Configuration
NEWS_API_KEY=your_news_api_key_here

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Mailing Configuration
# Strategy: SMTP or DESKTOP
MAIL_STRATEGY=DESKTOP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@outlook.com
SMTP_PASS=your-app-password
DEFAULT_FROM_EMAIL=your-email@outlook.com
